{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/digital-twin-skill/schemas/clone_test.schema.json",
  "title": "CloneTestResult",
  "description": "Verdict on which of two candidate messages was actually written by the user.",
  "type": "object",
  "required": ["prediction", "confidence", "analysis", "tells"],
  "properties": {
    "prediction": {
      "type": "string",
      "enum": ["A", "B", "tie"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "analysis": {
      "type": "string",
      "minLength": 20
    },
    "tells": {
      "type": "array",
      "description": "Specific features that drove the verdict, weighted.",
      "items": {
        "type": "object",
        "required": ["message", "feature", "weight"],
        "properties": {
          "message": { "type": "string", "enum": ["A", "B"] },
          "feature": { "type": "string", "minLength": 3 },
          "weight": { "type": "string", "enum": ["low", "medium", "high"] }
        },
        "additionalProperties": false
      },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
